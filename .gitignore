# System
.DS_Store
Thumbs.db

# ── Root hygiene: allowlist top-level entries; anything else at root is ignored ──
# WHY: tools (snapcoder, brain-explain, youtube-digest, playwright-mcp, …) write to
# their CWD, which is usually a checkout. `/*` makes EVERY new root file/dir ignored by
# default, so stray tool output never clutters `git status` or risks a commit. The
# specific denylist rules further down still refine WITHIN these re-included directories.
# Add a new legit framework top-level entry → add a matching `!/name` line here.
/*
!/.claude/
!/.cursorrules
!/.githooks/
!/.github/
!/.gitignore
!/.obsidian/
!/.windsurfrules
!/backlog/
!/CHANGELOG.md
!/CLAUDE.md
!/daily-notes/
!/docs/
!/learnings/
!/LICENSE
!/NOTICE
!/projects/
!/README.md
!/RELEASE_NOTES.md
!/scripts/
!/SECURITY.md
!/sessions/
!/setup.sh
!/system/
!/templates/
!/tests/
!/user-preferences/
!/VERSION
!/youtube-digest/
!/youtube-knowledge/

# Session and daily note content (personal, not shared)
sessions/**/*.md
!sessions/.gitkeep
!sessions/README.md
daily-notes/**/*.md
!daily-notes/.gitkeep
!daily-notes/README.md

# Environment
.env
.env.local
.env.*.local

# Logs
*.log

# Node
node_modules/

# Local analysis caches
.pi-lens/

# Machine-generated Pi extension tsconfig (generated by bootstrap-pi-macos.sh)
system/pi-config/extensions/tsconfig.json

# Obsidian (tracked minimal config; ignore machine/user state)
.obsidian/cache/
.obsidian/workspace.json
.obsidian/graph.json

# Obsidian community plugins (often contain user-specific state or tokens)
.obsidian/plugins/
.obsidian/community-plugins.json
.obsidian/hotkeys.json

# Brain runtime config (generated by setup.sh; machine-specific)
brain.json

# Personal layer (never committed). The trailing-slash form ignores the directory;
# the anchored bare form also ignores a `local` SYMLINK (dev checkout points it at the
# live brain's local/) so `git add -A` can never sweep the machine-specific link in.
local/
/local

# Shared knowledge layer — its own git repo, never swept into framework git
# (mirrors the local/ handling above; the anchored form also ignores a `shared` SYMLINK)
shared/
/shared

# Temporary Pi files and session data
.pi/agent/<auth-file>
.pi/agent/auth.json
.pi/agent/sessions/

# Personal/private agentBrain layers that must never be shared
learnings/M4-Memories/
system/Security/

# brain-hide-forget: forget batches and the runtime caches.
# Already covered by `local/` rule above; documented here for clarity.
local/.trash/**
local/.hidden-index.json
local/.parks-index.json

# Local (non-shared) markdown — convention for personal/project context
*.local.md

# Graphify outputs — generated by `brain-graph build` and supposed to live
# under `local/graphify-out/`. Belt-and-braces guard against any in-tree
# graphify-out/ dirs that appear if a build is interrupted before its move.
graphify-out/
# system/graphify-out is a symlink into local graphify output (not a real dir,
# so the trailing-slash pattern above does not catch it).
system/graphify-out

# Rust build artifacts (scanman rust-impl)
rust-impl/target/

# Runtime/tool output that can land in the checkout root when a tool is pointed
# at AGENTBRAIN_DIR instead of the live vault (snapcoder screenshots, stray addon
# data dirs, playwright-mcp page dumps). Belt-and-braces: these are never part of
# the public framework. release.sh also has a git-tracked-only leak gate as the
# real backstop — this just keeps the working tree and `git add -A` clean.
snapcoder/
vault/
.playwright-mcp/
# Loose screenshots dropped in the checkout root (macOS screencapture, ad-hoc UI
# grabs, playwright/manual captures). Root-anchored (leading /) so images tracked
# deeper in the tree — docs, skill assets, ableton lessons — still ship.
/*.png
/*.jpg
/*.jpeg

# Maintainer-only auto-push hook — private, not shipped to clones/contributors
.githooks/post-commit
