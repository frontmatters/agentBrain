#!/usr/bin/env bash
# list-parks — list parked agentBrain projects (status: paused | blocked)
# See ../SKILL.md for usage. Read-only.

set -euo pipefail

# Resolve BRAIN_DIR (handles symlinks per agentbrain-mirror-split-volumes pattern)
resolve_brain_dir() {
    if [ -n "${BRAIN_DIR:-}" ] && [ -d "$BRAIN_DIR" ]; then
        echo "$BRAIN_DIR"; return 0
    fi
    # Script-relative first: <root>/system/skills/<name>/bin/<self>. cd -P
    # resolves symlinked skill dirs, so dev/sandbox checkouts stay self-contained.
    local root
    root="$(cd -P "$(dirname "${BASH_SOURCE[0]}")/../../../.." 2>/dev/null && pwd -P || true)"
    if [ -n "$root" ] && [ -f "$root/system/rules.md" ]; then
        echo "$root"; return 0
    fi
    if command -v realpath >/dev/null 2>&1; then
        realpath "$HOME/agentBrain" 2>/dev/null && return 0
    fi
    if [ -d "$HOME/agentBrain" ]; then
        (cd "$HOME/agentBrain" && pwd -P) && return 0
    fi
    echo "${0##*/}: cannot resolve the agentBrain root" >&2
    exit 1
}

BRAIN_DIR="$(resolve_brain_dir)"

# Source visibility helpers (added by brain-hide-forget)
source "$BRAIN_DIR/system/lib/visibility.sh" 2>/dev/null || true

PROJECTS_DIR="$BRAIN_DIR/local/projects"

if [ ! -d "$PROJECTS_DIR" ]; then
    echo "list-parks: no projects directory at $PROJECTS_DIR" >&2
    exit 1
fi

FORMAT="table"
INCLUDE_HIDDEN=0
SHOW_UUID=0
for arg in "$@"; do
    case "$arg" in
        --json)  FORMAT="json" ;;
        --table) FORMAT="table" ;;
        --uuid)  SHOW_UUID=1 ;;
        --include-hidden) INCLUDE_HIDDEN=1 ;;
        -h|--help)
            cat <<EOF
list-parks — list parked agentBrain projects

Usage:
  list-parks [--table]           # human-readable (default)
  list-parks --table --uuid      # add UUID column (opt-in)
  list-parks --json              # machine-readable (always includes id)
  list-parks --include-hidden    # include hidden projects (marked [H])

Reads local/projects/*/index.md and includes only projects with
status: paused | blocked. Sorted by date desc.

JSON output always includes the project's UUID5 \`id\` field (canonical
identifier). Table output omits it by default to keep rows readable;
use --uuid to add a UUID column.
EOF
            exit 0
            ;;
        *) echo "list-parks: unknown arg '$arg'" >&2; exit 1 ;;
    esac
done

# Read a frontmatter field from a markdown file.
# $1 = file, $2 = field name
read_fm_field() {
    local file="$1" field="$2"
    awk -v f="$field" '
        BEGIN { in_fm=0; found=0 }
        /^---[[:space:]]*$/ { in_fm = !in_fm; if (in_fm == 0 && found == 0) exit; next }
        in_fm && $0 ~ "^"f":" {
            sub("^"f":[[:space:]]*", "")
            gsub(/^["'"'"']|["'"'"']$/, "")
            print
            found=1
            exit
        }
    ' "$file"
}

# Extract a representative one-liner from the project, with fallback chain:
# 1. First non-empty line of ## Status section (current work state)
# 2. First non-empty line of ## Goal section (what the project does)
# 3. First H1 title (project name)
# Then strip markdown formatting and truncate on a word boundary.
read_one_liner() {
    local file="$1"
    awk '
        BEGIN { in_status=0; in_goal=0; status_line=""; goal_line=""; h1_line="" }
        # Capture first H1
        /^# / && h1_line == "" {
            line = $0; sub(/^# +/, "", line); h1_line = line
        }
        # Section markers
        /^## Status/ { in_status=1; in_goal=0; next }
        /^## Goal/   { in_status=0; in_goal=1; next }
        /^## / && $0 !~ /^## Status/ && $0 !~ /^## Goal/ { in_status=0; in_goal=0; next }
        # Capture first non-empty line of each section
        in_status && NF > 0 && !/^---/ && status_line == "" { status_line = $0 }
        in_goal   && NF > 0 && !/^---/ && goal_line   == "" { goal_line   = $0 }
        END {
            if (status_line != "") print status_line
            else if (goal_line != "") print goal_line
            else if (h1_line != "") print h1_line
        }
    ' "$file" | sed -E '
        # Strip leading list/heading/quote markers: >, #, *, -
        s/^[[:space:]]*[>#*-]+[[:space:]]*//
        # Strip inline markdown delimiters: **bold**, __bold__, *italic*, `code`
        s/\*\*//g
        s/__//g
        s/\*//g
        s/`//g
        # Trim trailing whitespace
        s/[[:space:]]+$//
    ' | awk '
        {
            if (length($0) <= 60) { print; exit }
            line = substr($0, 1, 60)
            # Truncate on the last space at or after column 40 to avoid mid-word cuts
            for (i = length(line); i >= 40; i--) {
                if (substr(line, i, 1) == " ") {
                    print substr(line, 1, i - 1) "…"
                    exit
                }
            }
            # No good word boundary — hard truncate with ellipsis
            print line "…"
        }
    '
}

# Collect rows
declare -a rows=()
shopt -s nullglob
for index in "$PROJECTS_DIR"/*/index.md; do
    name="$(basename "$(dirname "$index")")"
    status="$(read_fm_field "$index" status)"
    [ -z "$status" ] && continue
    case "$status" in
        paused|blocked) ;;
        *) continue ;;
    esac

    # Hide filter (brain-hide-forget)
    HIDDEN_MARKER=""
    if is_hidden "$index" 2>/dev/null; then
        if [ "$INCLUDE_HIDDEN" -eq 0 ]; then
            continue
        fi
        HIDDEN_MARKER="[H] "
    fi

    priority="$(read_fm_field "$index" priority)"
    [ -z "$priority" ] && priority="-"

    # LAST TOUCHED — gebruik index.md mtime (precieser dan frontmatter date,
    # auto-update bij elke edit, format YYYY-MM-DD HH:MM)
    if date_str=$(date -r "$index" "+%Y-%m-%d %H:%M" 2>/dev/null); then
        date="$date_str"
    elif date_str=$(stat -c "%y" "$index" 2>/dev/null | cut -d'.' -f1 | cut -d' ' -f1-2 | awk '{print $1, substr($2,1,5)}'); then
        date="$date_str"
    else
        date="$(read_fm_field "$index" date)"
        [ -z "$date" ] && date="0000-00-00 00:00"
    fi
    id="$(read_fm_field "$index" id)"
    [ -z "$id" ] && id="-"
    oneline="$(read_one_liner "$index")"
    [ -z "$oneline" ] && oneline="(no Status paragraph)"
    rows+=("$date|$name|$status|$priority|$id|$oneline|$HIDDEN_MARKER")
done
shopt -u nullglob

if [ ${#rows[@]} -eq 0 ]; then
    # Clear stale index so /unpark <number> can't resolve to a removed project
    echo "[]" > "$BRAIN_DIR/local/.parks-index.json"
    if [ "$FORMAT" = "json" ]; then
        echo "[]"
    else
        echo "No parked work. (No paused/blocked projects in $PROJECTS_DIR.)"
    fi
    exit 0
fi

# Sort descending by date
sorted=()
while IFS= read -r _row; do sorted+=("$_row"); done < <(printf '%s\n' "${rows[@]}" | sort -r)

INDEX_FILE="$BRAIN_DIR/local/.parks-index.json"

# Write index file (used by /unpark <number>). Always written.
# Format: [{"n":1,"name":"foo-skill","id":"<uuid>","status":"paused","priority":"medium","date":"2026-06-02"}, ...]
{
    printf '['
    first=1
    idx=1
    for row in "${sorted[@]}"; do
        IFS='|' read -r d n s p i o m <<< "$row"
        [ $first -eq 0 ] && printf ','
        first=0
        printf '{"n":%d,"name":"%s","id":"%s","status":"%s","priority":"%s","date":"%s"}' \
            "$idx" "${n//\"/\\\"}" "${i//\"/\\\"}" "${s//\"/\\\"}" "${p//\"/\\\"}" "${d//\"/\\\"}"
        idx=$((idx+1))
    done
    printf ']\n'
} > "$INDEX_FILE"

if [ "$FORMAT" = "json" ]; then
    printf '['
    first=1
    idx=1
    for row in "${sorted[@]}"; do
        IFS='|' read -r d n s p i o m <<< "$row"
        [ $first -eq 0 ] && printf ','
        first=0
        printf '{"n":%d,"name":"%s","id":"%s","status":"%s","priority":"%s","date":"%s","oneline":"%s"}' \
            "$idx" "${n//\"/\\\"}" "${i//\"/\\\"}" "${s//\"/\\\"}" "${p//\"/\\\"}" "${d//\"/\\\"}" "${o//\"/\\\"}"
        idx=$((idx+1))
    done
    printf ']\n'
else
    if [ "$SHOW_UUID" -eq 1 ]; then
        printf '%-4s %-40s %-9s %-9s %-17s %-38s %s\n' "#" "PROJECT" "STATUS" "PRIORITY" "LAST TOUCHED" "UUID" "ONE-LINE"
    else
        printf '%-4s %-40s %-9s %-9s %-17s %s\n' "#" "PROJECT" "STATUS" "PRIORITY" "LAST TOUCHED" "ONE-LINE"
    fi
    idx=1
    for row in "${sorted[@]}"; do
        IFS='|' read -r d n s p i o m <<< "$row"
        if [ "$SHOW_UUID" -eq 1 ]; then
            printf '[%-2d] %-40s %-9s %-9s %-17s %-38s %s\n' "$idx" "${m}$n" "$s" "$p" "$d" "$i" "$o"
        else
            printf '[%-2d] %-40s %-9s %-9s %-17s %s\n' "$idx" "${m}$n" "$s" "$p" "$d" "$o"
        fi
        idx=$((idx+1))
    done
    echo ""
    echo "Resume: /unpark <name>  OR  /unpark <number>  (numbers valid until next /list-parks)"
fi
