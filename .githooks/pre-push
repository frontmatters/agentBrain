#!/usr/bin/env bash
# pre-push — fast doctor gate before sharing commits.
#
# Runs `doctor.sh --fast` (the cheap, high-signal structural + privacy checks +
# bash syntax) so the safe path is also the fast path — no reflex to bypass it.
# The slow checks (TypeScript pi-extension checks, the test suites, shellcheck)
# run in the FULL doctor, which still gates release-check, deploy's
# validate-install sandbox, and CI. Set PUSH_FULL_DOCTOR=1 to run the full
# doctor here too.
#
# Skip-escape: PUSH_SKIP_DOCTOR=1 git push … (use sparingly).

set -euo pipefail

if [[ "${PUSH_SKIP_DOCTOR:-0}" = "1" ]]; then
  echo "pre-push: PUSH_SKIP_DOCTOR=1 set — skipping doctor.sh" >&2
  exit 0
fi

# Serialize concurrent pushes (the post-commit auto-push racing a manual push)
# so two doctor.sh --fast runs don't collide and one spuriously reports failure.
# Portable mkdir-lock (no flock on macOS); bounded wait, and steal a lock left
# behind by a crashed run (>180s old) so it can never wedge pushes permanently.
lock="${TMPDIR:-/tmp}/agentbrain-prepush.lock"
held=0
for _ in $(seq 1 180); do
  if mkdir "$lock" 2>/dev/null; then held=1; break; fi
  mt="$(stat -f %m "$lock" 2>/dev/null || stat -c %Y "$lock" 2>/dev/null || echo 0)"
  if [[ "$mt" -gt 0 && $(( $(date +%s) - mt )) -gt 180 ]]; then
    rmdir "$lock" 2>/dev/null || true
  fi
  sleep 1
done
if [[ "$held" = 1 ]]; then
  trap 'rmdir "$lock" 2>/dev/null || true' EXIT
else
  echo "pre-push: proceeding without lock (held elsewhere >180s)" >&2
fi

if [[ -x scripts/doctor.sh ]]; then
  if [[ "${PUSH_FULL_DOCTOR:-0}" = "1" ]]; then
    DOCTOR_ARGS=""; echo "pre-push: running FULL doctor.sh (PUSH_FULL_DOCTOR=1)" >&2
  else
    DOCTOR_ARGS="--fast"; echo "pre-push: running doctor.sh --fast (full doctor runs in release-check/deploy/CI)" >&2
  fi
  # mktemp avoids symlink-clobber footgun in /tmp with predictable filename.
  log="$(mktemp -t agentbrain-doctor-prepush.XXXXXX)"
  # shellcheck disable=SC2086
  if ! bash scripts/doctor.sh $DOCTOR_ARGS >"$log" 2>&1; then
    echo "" >&2
    echo "✗ pre-push BLOCKED: doctor.sh failed. Last 30 lines:" >&2
    tail -30 "$log" >&2
    echo "" >&2
    echo "Full log: $log" >&2
    echo "Bypass (use sparingly): PUSH_SKIP_DOCTOR=1 git push …" >&2
    exit 1
  fi
  rm -f "$log"
  echo "pre-push: doctor.sh passed." >&2
fi
